{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "8652323496634eeca579dfaccb2fe064",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "MainLightShadows (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -187.0,
            "y": 399.99993896484377,
            "width": 262.9999694824219,
            "height": 278.00006103515627
        }
    },
    "m_Slots": [
        {
            "m_Id": "63340860e9314a1c9a18a88abdad500e"
        },
        {
            "m_Id": "58bb4da416f64f63aec9f213e049546c"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "MainLightShadows",
    "m_FunctionSource": "e6a3ff3b07b972845be3f496c6bae618",
    "m_FunctionBody": "#ifdef SHADERGRAPH_PREVIEW\r\n    ShadowAtten = 1.0;\r\n#else\r\n    #if defined(UNIVERSAL_LIGHTING_INCLUDED)\r\n        // Calcule les coordonnées de l'ombre à partir de la position dans le monde\r\n        float4 shadowCoord = TransformWorldToShadowCoord(WorldPos);\r\n        // Récupère la lumière principale et son atténuation (les ombres)\r\n        Light mainLight = GetMainLight(shadowCoord);\r\n        ShadowAtten = mainLight.shadowAttenuation;\r\n    #else\r\n        ShadowAtten = 1.0;\r\n    #endif\r\n#endif"
}

